# ---------------------------------------------------------------------------
# AI Access Governance Assistant dotenv template
# ---------------------------------------------------------------------------
# This file is safe to commit to GitHub because it contains placeholders only.
# Create your private runtime file with:
#
#   cp .env.example .env
#
# The application loads `.env` at startup with python-dotenv in `app/config.py`.
# Do not commit `.env`; it may contain cloud credentials and API keys.

# ---------------------------------------------------------------------------
# Local application mode
# ---------------------------------------------------------------------------
ENVIRONMENT=local

# memory = fully local demo mode
# postgres = use POSTGRES_DSN
# dynamodb = use DYNAMODB_* table names and AWS credentials
STORAGE_BACKEND=memory

# Keep true for offline demos with no cloud credentials or model API keys.
LOCAL_DEMO_MODE=true

# Directory containing example local policy files.
POLICY_DIR=app/policy

# ---------------------------------------------------------------------------
# Model provider
# ---------------------------------------------------------------------------
# local = deterministic parser, no model required
# bedrock = AWS Bedrock runtime
# openai = OpenAI/Codex provider path when implemented/configured
LLM_PROVIDER=local

# ---------------------------------------------------------------------------
# AWS Bedrock
# ---------------------------------------------------------------------------
# Keep BEDROCK_ENABLED=false for local demos.
# Use AWS Bedrock model IDs here only. Do not put OpenAI/Codex model names here.
BEDROCK_ENABLED=false
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Required only when using Bedrock or DynamoDB with real AWS access.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ---------------------------------------------------------------------------
# OpenAI / Codex
# ---------------------------------------------------------------------------
# Required only when LLM_PROVIDER=openai and an OpenAI provider is enabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2-codex

# ---------------------------------------------------------------------------
# Open Policy Agent
# ---------------------------------------------------------------------------
# Leave false for fully offline local demos.
# Set true when running OPA locally, for example with `docker compose up -d opa`.
OPA_ENABLED=false
OPA_URL=http://localhost:8181

# ---------------------------------------------------------------------------
# Optional persistence backends
# ---------------------------------------------------------------------------
# Used only when STORAGE_BACKEND=postgres.
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/access_governance

# Used only when STORAGE_BACKEND=dynamodb.
DYNAMODB_POLICY_TABLE=access-governance-policies
DYNAMODB_AUDIT_TABLE=access-governance-audit

# ---------------------------------------------------------------------------
# Governance defaults
# ---------------------------------------------------------------------------
DEFAULT_TENANT=zoneone
APPROVAL_THRESHOLD=65
REJECTION_THRESHOLD=85
